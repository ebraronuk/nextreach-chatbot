# =============================================================
# NextReach Chatbot — Environment Variables Template
# =============================================================
# Bu dosya commit edilir, GERCEK degerlerini .env.local'a yaz.
# .env.local Git'e GITMEZ (.gitignore ile korunuyor).
# =============================================================

# ---- Supabase (https://supabase.com/dashboard/project/_/settings/api) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here-NEVER-EXPOSE-TO-CLIENT

# ---- Google Gemini (https://aistudio.google.com/app/apikey) ----
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ---- Admin View Password (basit query-param koruma) ----
# /admin?key=<bu deger> ile erisilir
ADMIN_SECRET_KEY=change-me-to-something-long-and-random

# ---- Opsiyonel: Hot Lead Webhook (Slack / Discord / n8n) ----
# 80+ skorlu lead geldiginde POST atilir. Bos birakirsan kapali.
HOT_LEAD_WEBHOOK_URL=

# ---- App Konfigurasyon ----
NEXT_PUBLIC_APP_NAME=NextReach
NEXT_PUBLIC_APP_URL=http://localhost:3000
